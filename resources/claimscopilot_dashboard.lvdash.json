{
  "datasets": [
    {
      "name": "decisions",
      "displayName": "Decisions",
      "queryLines": [
        "SELECT created_at, agent_recommendation, COALESCE(adjuster_concurred, false) AS concurred, model, agent_version FROM __CATALOG__.app.decision_log"
      ]
    },
    {
      "name": "feedback",
      "displayName": "Feedback",
      "queryLines": [
        "SELECT created_at, thumbs, rating FROM __CATALOG__.app.feedback"
      ]
    },
    {
      "name": "escalations",
      "displayName": "Escalations",
      "queryLines": [
        "SELECT created_at, reason, queue FROM __CATALOG__.app.escalation"
      ]
    }
  ],
